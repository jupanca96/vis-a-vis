---
import caffee from "../assets/caffee.jpg?url";
---

<div class="section-image">
  <img
    class="section-img"
    src={caffee}
    alt="Caffee Image"
  />
</div>

<style>
  /* BLOQUE GLOBAL REUTILIZABLE */
  .section-image {
    width: 100%;
    height: 80vh;
    min-height: 500px;
    max-height: 800px;
    overflow: hidden;
    position: relative;
  }

  .section-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .section-image {
    width: 100%;
    height: 60vh;
    min-height: 300px;
    overflow: hidden;
  }

  .section-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 📱 MOBILE */
  @media (max-width: 1023px) {
    .section-image {
      height: 55vh;
      min-height: 280px;
    }
  }
</style>
