---
import food from "../assets/food2.jpg?url";
---

<div class="section-image">
  <img
    class="section-img"
    src={food}
    alt="Food Image"
  />
</div>

<style>
  .section-image {
    width: 100%;
    height: 60vh;
    min-height: 300px;
    max-height: 500px;
    overflow: hidden;
    position: relative;
  }

  .section-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .section-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.08);
  }

  /* 📱 MOBILE */
  @media (max-width: 1023px) {
    .section-image {
      height: 45vh;
      min-height: 250px;
    }
  }
</style>
