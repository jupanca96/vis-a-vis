---
import food from "../assets/food1.jpg?url";
import food2 from "../assets/food2.jpg?url";
import tables from "../assets/tables.jpg?url";
import facade from "../assets/restaurant-facade.jpg?url";
---

<section id="press-section" class="press-section">
  <h2 class="press-title">PRESS</h2>

  <div class="swiper press-carousel">
    <div class="swiper-wrapper">
      <!-- Slide 1 -->
      <div class="swiper-slide">
        <div class="press-card">
          <div class="image-container">
            <img class="image-hero" src={food} alt="Food Image" />
          </div>
          <div class="press-content">
            <p class="article-title">
              2019 STARCHEFS NEW YORK RISING STARS: WHY THEY SHINE
            </p>
            <p class="source">| STARCHEFS.COM</p>
          </div>
        </div>
      </div>

      <!-- Slide 2 -->
      <div class="swiper-slide">
        <div class="press-card">
          <div class="image-container">
            <img class="image-hero" src={food2} alt="Food Image" />
          </div>
          <div class="press-content">
            <p class="article-title">CUISINE INSPIRED</p>
            <p class="description">
              THE 2019 LIST OF NYC'S MICHELIN-STARRED RESTAURANTS
            </p>
          </div>
        </div>
      </div>

      <!-- Slide 3 -->
      <div class="swiper-slide">
        <div class="press-card">
          <div class="image-container">
            <img class="image-hero" src={tables} alt="Food Image" />
          </div>
          <div class="press-content">
            <p class="article-title">THRILLIST</p>
            <p class="description">
              EVERYWHERE YOU NEED TO EAT AND DRINK IN NYC RIGHT NOW
            </p>
          </div>
        </div>
      </div>

      <!-- Slide 4 -->
      <div class="swiper-slide">
        <div class="press-card">
          <div class="image-container">
            <img class="image-hero" src={facade} alt="Food Image" />
          </div>
          <div class="press-content">
            <p class="article-title">THRILLIST</p>
            <p class="description">
              EVERYWHERE YOU NEED TO EAT AND DRINK IN NYC RIGHT NOW
            </p>
          </div>
        </div>
      </div>

      <!-- Slide 5 -->
      <div class="swiper-slide">
        <div class="press-card">
          <div class="image-container">
            <img class="image-hero" src={food} alt="Food Image" />
          </div>
          <div class="press-content">
            <p class="article-title">THRILLIST</p>
            <p class="description">
              EVERYWHERE YOU NEED TO EAT AND DRINK IN NYC RIGHT NOW
            </p>
          </div>
        </div>
      </div>

      <!-- Slide 6 -->
      <div class="swiper-slide">
        <div class="press-card">
          <div class="image-container">
            <img class="image-hero" src={food2} alt="Food Image" />
          </div>
          <div class="press-content">
            <p class="article-title">THRILLIST</p>
            <p class="description">
              EVERYWHERE YOU NEED TO EAT AND DRINK IN NYC RIGHT NOW
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Flechas de navegación -->
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
  </div>
</section>

<style>
  .press-section {
    padding: 60px 20px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .press-title {
    text-align: center;
    font-size: 2.5rem;
    letter-spacing: 4px;
    margin-bottom: 50px;
    color: var(--text-color);
  }

  /* SWIPER */
  .press-carousel {
    width: 100%;
    overflow: hidden;
  }

  /* CARD */
  .press-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* IMAGEN */
  .image-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* TEXTO */
  .press-content {
    color: var(--text-color);
    font-size: 0.85rem;
    line-height: 1.4;
    letter-spacing: 1px;
    max-width: 250px;
    text-transform: uppercase;
  }

  .article-title {
    font-weight: bold;
    margin-bottom: 5px;
  }

  /* FLECHAS */
  .swiper-button-next,
  .swiper-button-prev {
    color: var(--text-color) !important;
    top: 50%;
    transform: translateY(-50%);
  }

  .swiper-button-next:after,
  .swiper-button-prev:after {
    font-size: 18px !important;
    font-weight: bold;
  }

  .swiper-button-prev {
    left: -10px;
  }

  .swiper-button-next {
    right: -10px;
  }

  .press-card {
    transition: transform 0.3s ease;
  }

  .press-card:hover {
    transform: translateY(-5px);
  }

  /* 📱 MOBILE */
  @media (max-width: 640px) {
    .press-title {
      font-size: 1.8rem;
      margin-bottom: 30px;
    }

    .press-content {
      font-size: 0.75rem;
      max-width: 90%;
    }

    .swiper-button-next,
    .swiper-button-prev {
      display: none; /* mejor UX en mobile */
    }
  }
</style>

<script>
  import "../scripts/press-swiper.js";
</script>
