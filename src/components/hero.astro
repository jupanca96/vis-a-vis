---
import facade from "../assets/restaurant_facade.jpg?url";
---

<div class="container-hero">
  <img class="image-hero" src={facade} alt="Restaurant Facade" />
</div>

<style>
  .container-hero {
    width: 100%;
    height: 911px;
    overflow: hidden;
    position: relative;
  }

  /* Imagen SIEMPRE cubre */
  .image-hero {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 📱 MOBILE */
  @media (max-width: 1023px) {
    .container-hero {
      height: 70vh; /* altura relativa a pantalla */
      min-height: 400px; /* evita que quede muy pequeña */
    }
  }
  .container-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2); /* leve oscurecido */
  }
</style>
