</section>

<style>
  .menu-section {
    background: #d9d4c7;
    padding: 80px 20px;
    text-align: center;
  }

  .title {
    font-size: 64px;
    letter-spacing: 4px;
    margin-bottom: 20px;
    color: #3b0f0f;
  }

  /* TABS */
  .tabs {
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tab {
    background: none;
    border: none;
    letter-spacing: 2px;
    cursor: pointer;
    padding: 5px 10px;
    white-space: nowrap;
  }

  .tab.active {
    border: 1px solid #3b0f0f;
  }

  /* BOTÓN */
  .btn {
    margin: 20px 0 50px;
    padding: 10px 20px;
    border: 2px solid #3b0f0f;
    background: transparent;
    cursor: pointer;
  }

  /* CONTENIDO */
  .container-items-menu {
    display: flex;
    flex-direction: column;
    gap: 60px;
    text-align: center;
    max-width: 900px;
    margin: auto;
  }

  .items {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  h2 {
    letter-spacing: 3px;
    margin-bottom: 20px;
  }

  .item {
    margin-bottom: 20px;
    max-width: 250px;
  }

  .item h3 {
    font-size: 14px;
    letter-spacing: 2px;
    margin: 0;
  }

  .item p {
    font-size: 13px;
    margin: 5px 0;
  }

  .item span {
    font-size: 13px;
  }

  /* ocultar menus */
  .menu-content {
    display: none;
  }

  .menu-content.active {
    display: block;
  }

  /* 📱 MOBILE */
  @media (max-width: 1023px) {
    .title {
      font-size: 40px;
      letter-spacing: 2px;
    }

    /* Tabs tipo scroll horizontal */
    .tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: flex-start;
      padding-bottom: 10px;
    }

    .tabs::-webkit-scrollbar {
      display: none;
    }

    .tab {
      font-size: 13px;
    }

    /* Items en columna */
    .items {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }

    .item {
      max-width: 100%;
    }

    .container-items-menu {
      gap: 40px;
    }

    .btn {
      margin: 20px 0 30px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll(".tab");
    const menus = document.querySelectorAll(".menu-content");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        // Remover active de todos los tabs
        tabs.forEach((t) => t.classList.remove("active"));
        tab.classList.add("active");

        // Ocultar todos los menús
        menus.forEach((menu) => menu.classList.remove("active"));

        // Mostrar el menú correspondiente
        const id = tab.dataset.menu;
        const activeMenu = document.getElementById(id);

        if (activeMenu) {
          activeMenu.classList.add("active");

          // Scroll suave hacia el contenido (mejora UX en mobile)
          activeMenu.scrollIntoView({
            behavior: "smooth",
            block: "start",
          });
        }
      });
    });
  });
</script>
