---

<section id="menu-section" class="menu-section">
  <div class="container">
    <h1 class="title">VIS·À·VIS MENU</h1>

    <div class="tabs-container">
      <div class="tabs">
        {
          menuData.map((cat, index) => (
            <button
              class={`tab ${index === 0 ? "active" : ""}`}
              data-menu={cat.id}
            >
              {cat.title}
            </button>
          ))
        }
      </div>
    </div>

    <div class="menu-display">
      {
        menuData.map((cat, index) => (
          <div
            class={`menu-content ${index === 0 ? "active" : ""}`}
            id={cat.id}
          >
            <h2 class="category-title">{cat.title}</h2>
            <div class="items-grid">
              {cat.items.map((item) => (
                <div class="menu-item">
                  <div class="item-header">
                    <h3>{item.name}</h3>
                    <span class="dots" />
                    <span class="price">{item.price}</span>
                  </div>
                  {item.desc && <p>{item.desc}</p>}
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .menu-section {
    background: #fdfcf9;
    padding: 60px 20px;
    min-height: 80vh;
  }

  .title {
    font-family: serif;
    text-align: center;
    letter-spacing: 5px;
    margin-bottom: 40px;
  }

  /* Scroll horizontal para las 9 categorías en móvil */
  .tabs-container {
    max-width: 1000px;
    margin: 0 auto 40px;
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
  }
  .tabs-container::-webkit-scrollbar {
    display: none;
  } /* Chrome/Safari */

  .tabs {
    display: flex;
    gap: 15px;
    padding: 10px;
    border-bottom: 1px solid #e0e0e0;
    white-space: nowrap;
  }

  .tab {
    background: none;
    border: none;
    font-size: 12px;
    font-weight: bold;
    letter-spacing: 1px;
    cursor: pointer;
    color: #888;
    transition: 0.3s;
    text-transform: uppercase;
  }

  .tab.active {
    color: #000;
    border-bottom: 2px solid #000;
  }

  /* Contenido */
  .menu-content {
    display: none;
    max-width: 800px;
    margin: auto;
    animation: fadeIn 0.4s ease;
  }
  .menu-content.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .category-title {
    text-align: center;
    font-size: 1.5rem;
    margin-bottom: 30px;
    letter-spacing: 3px;
  }

  .menu-item {
    margin-bottom: 20px;
  }

  .item-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .item-header h3 {
    font-size: 1rem;
    margin: 0;
    text-transform: uppercase;
  }

  /* Los puntos elegantes */
  .dots {
    flex: 1;
    border-bottom: 2px dotted #ccc;
    height: 12px;
  }

  .price {
    font-weight: bold;
  }

  .menu-item p {
    font-size: 0.9rem;
    color: #666;
    margin: 5px 0 0;
    font-style: italic;
  }
</style>

